# Copy this file to `.env` and fill in real values. Never commit `.env`.
# See README.md for setup on a new machine.

# ---- AWS (required for Rekognition face detection) ----
# Prefer IAM role on ECS/EC2; use keys only for local dev.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Optional: if the eyewear catalog lives in a different account, set these; else main AWS_* is used
# S3_CATALOG_ACCESS_KEY_ID=
# S3_CATALOG_SECRET_ACCESS_KEY=
# S3_CATALOG_REGION=ap-south-1

# ---- S3 eyewear catalog (flat layout: lusmt{ID}_{view}.jpg) ----
S3_CATALOG_BUCKET=
# Parent folder above Glass/ (usually EMPTY if Glass/ is at bucket root). Do not set this to "all_images"
# unless that folder truly wraps Glass/; sunglass "all_images" is S3_GLASS_SUNGLASS_EXTRA_PREFIX instead.
S3_CATALOG_PREFIX=

# Split under …/Glass/Sunglass/ vs …/Glass/Normal_glass/ (Streamlit + API; case-sensitive in S3). Set false to use the full prefix only.
# S3_USE_GLASS_SUBFOLDERS=true
# S3_GLASS_PARENT=Glass
# S3_GLASS_SUNGLASS_FOLDER=Sunglass
# S3_GLASS_EYEGLASS_FOLDER=Normal_glass
# Asymmetric layout: sun often under …/Sunglass/all_images/; normal often directly under …/Normal_glass/
# S3_GLASS_SUNGLASS_EXTRA_PREFIX=all_images
# S3_GLASS_EYEGLASS_EXTRA_PREFIX=

# Optional manifest path if you use DB/API manifest mode
# S3_CATALOG_MANIFEST_KEY=manifest.json
# S3_REGIONAL_JSON_KEY=regional_affinity.json
# S3_USER_IMAGES_BUCKET=
# S3_USER_IMAGES_KEY_PREFIX=uploads/

# ---- App / API ----
DATABASE_URL=sqlite:///./rs2.db
# For Docker Postgres: postgresql+psycopg2://rs2:rs2@localhost:5432/rs2
CATALOG_SOURCE=auto
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DISABLE_AUTH=true
# API_BEARER_TOKEN=

# Hybrid: CLIP preference vs rule-based inner score (defaults 0.6 / 0.4) — tune here, not in the Streamlit UI
# USE_PREFERENCE_HYBRID=true
# HYBRID_W_PREFERENCE=0.6
# HYBRID_W_FACE=0.4
# CLIP_PREFERENCE_ENABLED=true

# ---- Ranking / embeddings (must match vector length in catalog) ----
EMBEDDING_DIM=8
# EMBEDDING_JSON=/path/to/prototype_vectors.json
# EMBEDDING_PROTO_JSON={"round":[0.1,...]}

# AWS alias (optional; often same as AWS_DEFAULT_REGION)
# AWS_REGION=ap-south-1
